		"test": "npm run test:arch && npm run test:providers && npm run test:chat-core && npm run test:domains",
		"validate:arch": "npm run lint:arch && npm run lint:taste && npm run test:arch",
		"cleanup": "tsx infra/cleanup.ts",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "npm run lint:eslint && npm run lint:arch && npm run lint:taste"
	},
